# ─── Crate — environment template ─────────────────────────────────────────
# Copy to `.env` (pipeline) and set the same values in Vercel (web) and
# GitHub Actions secrets (nightly pipeline). NEVER commit the filled-in .env.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + keys (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...                      # public anon key (client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # server-only; never exposed to the client

# Transaction pooler (pgBouncer, port 6543) — used by the Next.js app.
# Settings → Database → Connection string → "Transaction" pooler.
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Read-only role connection — backs /api/query (text-to-SQL). Create the role's
# password once (see supabase/README.md), then use it here. Pooler, port 6543.
SUPABASE_DB_URL_READONLY=postgresql://crate_readonly:READONLY_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Discogs (credits / personnel) ────────────────────────────────────────────
DISCOGS_TOKEN=YOUR_DISCOGS_PERSONAL_ACCESS_TOKEN

# ── MusicBrainz (requires a real contact email in the User-Agent) ────────────
MUSICBRAINZ_APP_CONTACT=you@example.com

# ── Tidal ────────────────────────────────────────────────────────────────────
# Path to the OAuth session file written by `python -m pipeline.auth_tidal`.
TIDAL_SESSION_FILE=.tidal-session.json

# ── On-demand sync endpoint (web → GitHub Actions repository_dispatch) ────────
# Shared secret the web app requires on POST /api/sync.
SYNC_SECRET=choose-a-long-random-string
# Fine-grained GitHub PAT with "Actions: write" on Hyphycodes/Tidal-Music,
# used by /api/sync to trigger the nightly workflow on demand.
GITHUB_DISPATCH_TOKEN=github_pat_...
GITHUB_REPO=Hyphycodes/Tidal-Music

# ── Misc ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployed web app (used by a few server helpers).
NEXT_PUBLIC_APP_URL=http://localhost:3000
